{
  "model": "sonnet",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/context-mode-cache-heal.mjs"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest --config ~/.claude/ccstatusline-settings.json",
    "padding": 0
  },
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "codex@openai-codex": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "firecrawl@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "remember@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context-mode@context-mode": true,
    "obsidian@obsidian-skills": true,
    "watch@claude-video": true,
    "dbg@claude-skills-laur": true,
    "ppc@claude-skills-laur": true,
    "sdd@claude-skills-laur": true,
    "skill-check@claude-skills-laur": true,
    "telegram@claude-skills-laur": true,
    "wbs@claude-skills-laur": true,
    "pmpt@claude-skills-laur": true
  },
  "extraKnownMarketplaces": {
    "karpathy-skills": {
      "source": {
        "source": "git",
        "url": "https://github.com/forrestchang/andrej-karpathy-skills.git"
      }
    },
    "openai-codex": {
      "source": {
        "source": "git",
        "url": "https://github.com/openai/codex-plugin-cc.git"
      }
    },
    "context-mode": {
      "source": {
        "source": "git",
        "url": "https://github.com/mksglu/context-mode.git"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "git",
        "url": "https://github.com/kepano/obsidian-skills.git"
      }
    },
    "claude-video": {
      "source": {
        "source": "git",
        "url": "https://github.com/bradautomates/claude-video.git"
      }
    },
    "claude-skills-laur": {
      "source": {
        "source": "git",
        "url": "https://github.com/OnlineNM/claude-code-skills.git"
      }
    }
  },
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "theme": "dark",
  "effortLevel": "medium",
  "voiceEnabled": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "language": "Romanian",
  "skipDangerousModePermissionPrompt": true
}
