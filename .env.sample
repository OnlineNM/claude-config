# Claude Code provisioning — copy this file to .env and fill in the values
# Never commit .env to git

# OAuth token from ~/.claude.json after first manual login
CLAUDE_CODE_OAUTH_TOKEN=

# Account details from ~/.claude.json -> oauthAccount
CLAUDE_ACCOUNT_UUID=
CLAUDE_EMAIL=
CLAUDE_ORG_UUID=

# Git repo containing your dotfiles (optional)
# e.g.: https://github.com/user/dotfiles.git
CLAUDE_DOTFILES_REPO=

# Firecrawl
FIRECRAWL_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenRouter
OPENROUTER_API_KEY=