{
  "version": "1.0.0",
  "defaultProfile": "free",
  "customEndpoints": {
    "cloudflare-glm": {
      "kind": "complex",
      "displayName": "Cloudflare Workers AI (GLM 5.2)",
      "transport": "openai",
      "baseUrl": "https://api.cloudflare.com/client/v4/accounts/${CLOUDFLARE_ACCOUNT_ID}/ai",
      "apiPath": "/v1/chat/completions",
      "apiKey": "${CUSTOM_CLOUDFLARE_GLM_KEY}",
      "modelPrefix": "@cf/zai-org/"
    }
  },
  "profiles": {
    "cloudflare-glm": {
      "name": "cloudflare-glm",
      "models": {
        "opus":     "cloudflare-glm@glm-5.2",
        "sonnet":   "cloudflare-glm@glm-5.2",
        "haiku":    "cloudflare-glm@glm-5.2",
        "subagent": "cloudflare-glm@glm-5.2"
      }
    },
   "glm-openrouter": {
      "name": "glm-openrouter",
      "models": {
        "opus":     "or@z-ai/glm-5.2",
        "sonnet":   "or@z-ai/glm-5-turbo",
        "haiku":    "or@z-ai/glm-4.7",
        "subagent": "or@z-ai/glm-4.7-flash"
      }
    },
    "frontier": {
      "name": "frontier",
      "models": {
        "opus":     "or@google/gemini-3.1-pro-preview",
        "sonnet":   "or@z-ai/glm-5.2",
        "haiku":    "or@deepseek/deepseek-v4-flash",
        "subagent": "or@qwen/qwen3-coder"
      }
    },
    "balanced": {
      "name": "balanced",
      "models": {
        "opus":     "or@google/gemini-2.5-pro",
        "sonnet":   "or@deepseek/deepseek-v4-flash",
        "haiku":    "or@meta-llama/llama-4-scout",
        "subagent": "or@google/gemini-2.5-flash"
      }
    },
    "economy": {
      "name": "economy",
      "models": {
        "opus":     "or@deepseek/deepseek-v4-flash",
        "sonnet":   "or@qwen/qwen3-coder",
        "haiku":    "or@google/gemini-2.5-flash-lite",
        "subagent": "or@meta-llama/llama-4-scout"
      }
    },
    "free": {
      "name": "free",
      "models": {
        "opus":     "or@openrouter/free",
        "sonnet":   "or@qwen/qwen3-coder:free",
        "haiku":    "or@meta-llama/llama-3.3-70b-instruct:free",
        "subagent": "or@deepseek/deepseek-v4-flash:free"
      }
    },
    "local": {
      "name": "local",
      "models": {
        "opus": "ollama@llama3.1:8b-64k",
        "sonnet": "ollama@qwen2.5-coder:7b-64k",
        "haiku": "ollama@phi4-mini-64k:latest",
        "subagent": "ollama@mistral:7b-64k"
      }
    }
  }
}